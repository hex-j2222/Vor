<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="SidebarButton">
        <item name="android:layout_width">42dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:background">@drawable/bg_sidebar_btn</item>
        <item name="android:tint">@color/text_muted</item>
        <item name="android:layout_marginTop">1dp</item>
        <item name="android:layout_marginBottom">1dp</item>
    </style>

    <style name="ToolButton">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:background">@drawable/bg_btn_icon</item>
        <item name="android:tint">@color/text_secondary</item>
        <item name="android:layout_marginStart">1dp</item>
        <item name="android:layout_marginEnd">1dp</item>
    </style>

    <style name="ToolDivider">
        <item name="android:layout_width">1dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:background">@color/border_dim</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:layout_marginEnd">4dp</item>
    </style>

    <style name="PlaybackButton">
        <item name="android:layout_width">32dp</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:background">@drawable/bg_btn_icon</item>
        <item name="android:tint">@color/text_secondary</item>
    </style>

    <style name="PropLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textAllCaps">true</item>
    </style>

</resources>
