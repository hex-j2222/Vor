<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Nebula" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_nova</item>
        <item name="colorPrimaryVariant">@color/accent_pulsar</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_quasar</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/bg_panel</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorBackground">@color/bg_void</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorError">#FFCF6679</item>
        <item name="android:statusBarColor">@color/bg_void</item>
        <item name="android:navigationBarColor">@color/bg_deep</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowBackground">@color/bg_void</item>
    </style>

    <style name="Theme.Nebula.Splash" parent="Theme.Nebula">
        <item name="android:windowBackground">@color/bg_void</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
